{
  "name": "codenovel",
  "displayName": "CodeNovel",
  "description": "Read EPUB books disguised as source code or markdown notes — a stealth reader for your editor.",
  "version": "1.0.0",
  "publisher": "xxloveslife",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": { "type": "git", "url": "https://github.com/xxloveslife/codenovel.git" },
  "bugs": { "url": "https://github.com/xxloveslife/codenovel/issues" },
  "homepage": "https://github.com/xxloveslife/codenovel#readme",
  "keywords": ["epub", "reader", "ebook", "novel", "stealth", "boss key", "reading", "摸鱼", "小说", "阅读"],
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "stealthReader.openBook", "title": "CodeNovel: Open Book" },
      { "command": "stealthReader.nextPage", "title": "CodeNovel: Next Page" },
      { "command": "stealthReader.prevPage", "title": "CodeNovel: Previous Page" },
      { "command": "stealthReader.bossKey", "title": "CodeNovel: Boss Key (Toggle)" },
      { "command": "stealthReader.gotoChapter", "title": "CodeNovel: Go to Chapter" }
    ],
    "keybindings": [
      { "command": "stealthReader.nextPage", "key": "alt+]", "when": "stealthReader.active" },
      { "command": "stealthReader.prevPage", "key": "alt+[", "when": "stealthReader.active" },
      { "command": "stealthReader.bossKey", "key": "alt+q", "when": "stealthReader.active" }
    ],
    "configuration": {
      "title": "CodeNovel",
      "properties": {
        "stealthReader.charsPerLine": {
          "type": "number", "default": 40, "minimum": 1,
          "description": "每行字数（全角计 1，半角计 0.5）"
        },
        "stealthReader.linesPerPage": {
          "type": "number", "default": 25, "minimum": 1,
          "description": "每页行数"
        },
        "stealthReader.textColor": {
          "type": "string", "default": "#6A9955",
          "description": "正文颜色（默认近似深色主题注释绿）"
        },
        "stealthReader.commentPrefix": {
          "type": "string", "enum": ["auto", "#", "//"], "default": "auto",
          "description": "注释前缀；auto 按伪装文档语言推断（仅代码模式）"
        },
        "stealthReader.fakeCodeEvery": {
          "type": "integer", "default": 4, "minimum": 1, "maximum": 50,
          "description": "平均每连续多少行正文插入一段伪装代码/结构"
        },
        "stealthReader.fakeCodeBlock": {
          "type": "integer", "default": 1, "minimum": 0, "maximum": 10,
          "description": "每段伪装代码的平均行数（0 = 关闭混排）"
        },
        "stealthReader.fakeCodeJitter": {
          "type": "number", "default": 0.5, "minimum": 0, "maximum": 1,
          "description": "块大小随机幅度：0 完全规整，1 在均值 0~2 倍间浮动（固定种子，翻页不跳动）"
        },
        "stealthReader.fakeCodeLines": {
          "type": "array", "items": { "type": "string" }, "default": [],
          "description": "自定义伪装行（按顺序循环使用）；留空：代码模式用内置 Python 片段，Markdown 模式用内置笔记片段"
        },
        "stealthReader.disguiseMode": {
          "type": "string", "enum": ["code", "markdown"],
          "enumDescriptions": ["伪装成 Python 代码文件 util.py", "伪装成 Markdown 笔记 notes.md"],
          "default": "code",
          "description": "伪装载体：代码文件 或 Markdown 笔记"
        },
        "stealthReader.widthJitter": {
          "type": "number", "default": 0.15, "minimum": 0, "maximum": 0.6,
          "description": "每行字数随机浮动幅度，让正文右边缘参差更自然（0 = 整齐）"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "icon": "node scripts/make-icon.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.4.0",
    "jszip": "^3.10.1"
  }
}
